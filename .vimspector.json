{
  "adapters": {
    "netcoredbg": {
      "command": [ "netcoredbg", "--interpreter=vscode" ]
    }
  },
  "configurations": {
    "launch": {
      "adapter": "netcoredbg",
      "configuration": {
        "request": "launch",
        "program": "${workspaceRoot}/bin/Debug/net10.0/Sim.dll",
       "args": [ "--humans", "10", "--obstacles", "3", "--width", "1600", "--height", "1600", "--seed", "3034405504O" ],
        "stopAtEntry": false,
        "cwd": "${workspaceRoot}"
      }
    }
  }
}
